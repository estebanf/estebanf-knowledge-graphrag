# Copy to .env and fill in values before running scripts/start.sh

# PostgreSQL (required)
POSTGRES_PASSWORD=changeme
POSTGRES_USER=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432

# PostgreSQL tuning (optional — defaults are fine for dev)
# POSTGRES_SHARED_BUFFERS=512MB
# POSTGRES_WORK_MEM=64MB
# POSTGRES_MAINTENANCE_WORK_MEM=256MB
# POSTGRES_MAX_CONNECTIONS=50

# Memgraph (optional — defaults are fine)
MEMGRAPH_BOLT_PORT=7687
MEMGRAPH_LAB_PORT=3000
MEMGRAPH_MEMORY_LIMIT=2048

# Application connection strings (used by the RAG app, not docker-compose)
POSTGRES_URL=postgresql://rag:${POSTGRES_PASSWORD}@localhost:5432/rag
MEMGRAPH_URL=bolt://localhost:7687

# Storage
STORAGE_BASE_PATH=./data/documents

# OpenRouter (required for LLM calls)
OPENROUTER_API_KEY=

# Model roles — all accessed via OpenRouter
MODEL_METADATA_EXTRACTION=google/gemma-3-4b-it
MODEL_DOC_PROFILING=google/gemma-3-4b-it
MODEL_CHUNK_VALIDATION=qwen/qwen2.5-7b-instruct
MODEL_ENTITY_EXTRACTION=qwen/qwen-2.5-7b-instruct
MODEL_RELATIONSHIP_EXTRACTION=qwen/qwen-2.5-7b-instruct
MODEL_PROPOSITION_CHUNKING=qwen/qwen2.5-14b-instruct
MODEL_RETRIEVAL_QUERY_VARIANTS=google/gemini-2.5-flash-lite
MODEL_RETRIEVAL_GRAPH=google/gemini-2.5-flash-lite
MODEL_RETRIEVAL_RERANKER=cohere/rerank-v3.5

# Embedding model (via OpenRouter embeddings endpoint)
MODEL_EMBEDDING=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=4096

# Retrieval defaults
RETRIEVAL_RRF_K=60
RETRIEVAL_RRF_SCORE_FLOOR=0.0
RETRIEVAL_SEED_COUNT=10
RETRIEVAL_RESULT_COUNT=5
RETRIEVAL_MAX_DECOMPOSED_QUERIES=5
RETRIEVAL_FIRST_STAGE_TOP_N=20
RETRIEVAL_FUSED_CANDIDATE_COUNT=50
RETRIEVAL_ENTITY_SELECTION_COUNT=5
RETRIEVAL_SECOND_HOP_SELECTION_COUNT=5
RETRIEVAL_FIRST_HOP_CHUNK_COUNT=5
RETRIEVAL_SECOND_HOP_CHUNK_COUNT=5
RETRIEVAL_FIRST_HOP_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_SECOND_HOP_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_ENTITY_CONFIDENCE_THRESHOLD=0.75
RETRIEVAL_MAX_GRAPH_LLM_CALLS=100
RETRIEVAL_MAX_GRAPH_EXPANSION_MS=4000
RETRIEVAL_MAX_GRAPH_EXPANSION_MS_PER_SEED=4000
RETRIEVAL_TEXT_SEARCH_CONFIG=english
RETRIEVAL_WEIGHT_ORIGINAL=1.0
RETRIEVAL_WEIGHT_DECOMPOSED=1.0
RETRIEVAL_WEIGHT_EXPANDED=0.85
RETRIEVAL_WEIGHT_STEP_BACK=0.75
RETRIEVAL_WEIGHT_HYDE=0.65
RETRIEVAL_FINAL_ROOT_WEIGHT=0.60
RETRIEVAL_FINAL_FIRST_HOP_WEIGHT=0.25
RETRIEVAL_FINAL_SECOND_HOP_WEIGHT=0.15
RETRIEVAL_MULTI_PATH_BONUS=0.05
RETRIEVAL_SAME_SOURCE_NEIGHBOR_WINDOW=2
RETRIEVAL_SAME_SOURCE_NEIGHBOR_COUNT=3
RETRIEVAL_TRACE_MAX_CANDIDATES=5
RETRIEVAL_TRACE_MAX_ENTITIES=5

# Chunking / validation
CHUNK_VALIDATION_SAMPLE_RATE=0.10
CHUNK_VALIDATION_SAMPLE_RATE_HIGH_STAKES=0.25

# Relationship extraction
RELATIONSHIP_CONFIDENCE_THRESHOLD=0.75
ENTITY_DEDUP_COSINE_THRESHOLD=0.92

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
